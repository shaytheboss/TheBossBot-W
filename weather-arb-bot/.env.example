# Database (Railway provides automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/weatherarb

# Redis (optional, Railway provides)
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string

# API Keys
WUNDERGROUND_API_KEY=           # optional, used as fallback
OPENWEATHER_API_KEY=            # fallback weather source
POLYMARKET_API_KEY=             # if accessing private markets

# App Config
APP_ENV=development
SECRET_KEY=your_random_secret_key_here
CORS_ORIGINS=http://localhost:3000,https://your-dashboard.up.railway.app

# Scheduler Intervals (seconds)
METAR_FETCH_INTERVAL=300
POLYMARKET_FETCH_INTERVAL=30
WUNDERGROUND_FETCH_INTERVAL=1800
ANALYZER_RUN_INTERVAL=120

# Alert Thresholds
MIN_CONFIDENCE_FOR_ALERT=60
MIN_EDGE_FOR_ALERT=0.15
ALERT_DEDUP_MINUTES=30

# Sentry (optional)
SENTRY_DSN=
